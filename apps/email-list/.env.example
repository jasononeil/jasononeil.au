# Database Configuration
 MYSQL_HOST=localhost
 MYSQL_PORT=3306
 MYSQL_USER=root
 MYSQL_PASSWORD=password
 MYSQL_DB=email_list

 # Email Configuration
 # Get your API key from https://resend.com/api-keys
 RESEND_API_KEY=your_resend_api_key
 RESEND_RATE_LIMIT_PER_SE=2
 DEFAULT_FROM_EMAIL=newsletter@newsletter.jasononeil.au
 DEFAULT_FROM_NAME=Jason O'Neil
 TEST_EMAIL=your-test-email@example.com
 LOCAL_DEVELOPMENT=true

 # WordPress API Configuration
 WP_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
 WP_API_USERNAME=your_api_username
 WP_API_PASSWORD=your_api_password

 # Application Settings
 NODE_ENV=development
